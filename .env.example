# FreeSWITCH ESL Connection
FS_HOST=127.0.0.1
FS_PORT=8021
FS_PASSWORD=ClueCon

# SIP Gateway configured in FreeSWITCH
SIP_GATEWAY=mygateway
CALLER_ID_NUMBER=1234567890
CALLER_ID_NAME=Dialer

# Anthropic Claude API
ANTHROPIC_API_KEY=your-api-key-here
