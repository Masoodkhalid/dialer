# Dialer Settings
MAX_CONCURRENT_CALLS=10
DIAL_TIMEOUT=30
WRAP_UP_TIME=30
DROP_RATE_LIMIT=0.03
PACING_INTERVAL=5.0
AMD_ENABLED=true

# Web Server
HOST=0.0.0.0
PORT=8000
