# ── YOUR VoIP Switch ──────────────────────────────────────────────────────────
# Replace with your actual VoIP switch IP
FS_HOST=YOUR_VOIP_SWITCH_IP        # e.g. 103.45.67.89
FS_PORT=8021                        # FreeSWITCH ESL port (default 8021)
FS_PASSWORD=ClueCon                 # ESL password (check /etc/freeswitch/autoload_configs/event_socket.conf.xml)

# SIP Gateway name — must match gateway name in FreeSWITCH sip_profiles
SIP_GATEWAY=telcastc                # matches VICIdial SIP/telcastc channel name
DIAL_PREFIX=4164#                   # carrier route code — matches VICIdial: Dial(SIP/telcastc/4164#...)
CALLER_ID_NUMBER=18001234567        # your outbound DID number
CALLER_ID_NAME=MyDialer

# ── Anthropic Claude (optional — for AI call summaries) ───────────────────────
ANTHROPIC_API_KEY=

# ── Dialer Settings ────────────────────────────────────────────────────────────
MAX_CONCURRENT_CALLS=10
DIAL_TIMEOUT=30
WRAP_UP_TIME=30
DROP_RATE_LIMIT=0.03
PACING_INTERVAL=5.0
AMD_ENABLED=false

# ── Call Recording ─────────────────────────────────────────────────────────────
RECORDING_ENABLED=true
RECORDING_DIR=/var/lib/freeswitch/recordings   # path ON your FreeSWITCH server
RECORDING_FORMAT=wav                            # wav or mp3

# ── Web Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
