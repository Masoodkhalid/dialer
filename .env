# ── FreeSWITCH Server ─────────────────────────────────────────────────────────
FS_HOST=YOUR_SERVER_IP              # your FreeSWITCH server public IP (e.g. 103.45.67.89)
FS_PORT=8021
FS_PASSWORD=ClueCon

# ── SIP Gateway / Carrier ─────────────────────────────────────────────────────
# Must match the <gateway name="..."> in your FreeSWITCH XML file
# See: server_setup/telnyx_gateway.xml  OR  server_setup/voipms_gateway.xml
SIP_GATEWAY=telnyx                  # use "voipms" if switching to VoIP.ms

# No prefix needed for Telnyx or VoIP.ms — leave blank
DIAL_PREFIX=

# Your outbound caller ID — the DID number you bought from your carrier (E.164, no +)
CALLER_ID_NUMBER=1XXXXXXXXXX        # e.g. 18005551234
CALLER_ID_NAME=MyDialer

# ─── OLD SIPNAV (cannot route to US mobile — do not use) ─────────────────────
# SIP_GATEWAY=telcastc
# DIAL_PREFIX=4164#

# ── Anthropic Claude (optional — for AI call summaries) ───────────────────────
ANTHROPIC_API_KEY=

# ── Dialer Settings ────────────────────────────────────────────────────────────
MAX_CONCURRENT_CALLS=10
DIAL_TIMEOUT=30
WRAP_UP_TIME=30
DROP_RATE_LIMIT=0.03
PACING_INTERVAL=5.0
AMD_ENABLED=false

# ── Call Recording ─────────────────────────────────────────────────────────────
RECORDING_ENABLED=true
RECORDING_DIR=/var/lib/freeswitch/recordings   # path ON your FreeSWITCH server
RECORDING_FORMAT=wav                            # wav or mp3

# ── Web Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
